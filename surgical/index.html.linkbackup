<div class="page small">
	<section class="about-contantlens">
		<div class="about-contantlens-inner">
			<div class="about-contantlens-img">
				<picture>
					<source media="(max-width:520px)" srcset="../wp-content/themes/ikuwaganka/images/femtosecond-surgery-sp.jpg">
