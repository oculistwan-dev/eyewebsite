<style>
/* Windows兼容性修复 */
* {
    -webkit-box-sizing: border-box;
    -moz-box-sizing: border-box;
    box-sizing: border-box;
}
body {
    font-family: 'Microsoft YaHei', '微软雅黑', 'PingFang SC', 'Hiragino Sans GB', 'Heiti SC', '黑体', 'Noto Sans CJK SC', 'Source Han Sans CN', 'WenQuanYi Micro Hei', '文泉驿微米黑', 'Droid Sans Fallback', 'SimSun', '宋体', Arial, sans-serif !important;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
}
/* 修复Windows下的flex布局问题 */
.wrap, .header, .footer, .cta-inner {
    display: block;
    width: 100%;
}
/* 确保图片在Windows下正常显示 */
img {
    max-width: 100%;
    height: auto;
    display: block;
}
/* 修复Windows下的背景图片问题 */
.cta {
    background-attachment: scroll !important;
}
</style>
<title>万道红屈光性白内障工作室 | 华夏眼科集团徐州复兴眼科医院</title>
<meta name='robots' content='max-image-preview:large' />
<!-- 已移除海外DNS预取，提升国内访问速度 -->

<meta name="description" content="万道红屈光性白内障工作室主要是开展白内障手术特别是屈光性白内障手术的华夏眼科集团徐州复兴眼科医院的工作室。我们的白内障手术可以预约日间手术也可以住院两天即可出院。我们华夏眼科集团徐州复兴眼科医院还设有屈光手术中心、青少年视光中心、眼底病、白内障及青光眼科、眼表及眼外伤病科。">
<link rel="canonical" href="https://www.xuzhoucataract.com/">
<meta property="og:locale" content="zh_CN">
<meta property="og:type" content="website">
<meta property="og:image" content="https://www.xuzhoucataract.com/assets/images/ogp.jpg">
<meta property="og:title" content="万道红屈光性白内障工作室｜华夏眼科集团徐州复兴眼科医院">
<meta property="og:description" content="万道红屈光性白内障工作室主要是开展白内障手术特别是屈光性白内障手术的华夏眼科集团徐州复兴眼科医院的工作室。我们的白内障手术可以预约日间手术也可以住院两天即可出院。我们华夏眼科集团徐州复兴眼科医院还设有屈光手术中心、青少年视光中心、眼底病、白内障及青光眼科、眼表及眼外伤病科。">
<meta property="og:url" content="https://www.xuzhoucataract.com/">
